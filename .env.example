# HTTP server
PORT=3000
HOST=0.0.0.0

# Caller authentication. Leaving this unset disables caller auth and is unsafe outside local dev.
PROXY_API_KEY=

# ChatGPT/Codex OAuth credentials. Use `npm run build && npm run login` to obtain these.
OPENAI_REFRESH_TOKEN=
OPENAI_ACCESS_TOKEN=
OPENAI_EXPIRES_AT=
OPENAI_CHATGPT_ACCOUNT_ID=

# Upstream Codex backend. The default URL plus path becomes:
# https://chatgpt.com/backend-api/codex/v1/responses
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
CODEX_RESPONSES_PATH=/v1/responses

# Comma-separated model ids returned by /v1/models.
CODEX_MODELS=gpt-5.5,gpt-5.5-pro,gpt-5.4,gpt-5.4-mini
